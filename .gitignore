!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
/build

# Production
*.tsbuildinfo
next-env.d.ts

# Misc
.DS_Store
*.pem
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Environment files (NEVER commit API tokens)
.env*
!.env.example

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Vercel
.vercel

# IDE
.vscode/
.idea/
*.swp
*.swo

# Database (user-specific)
*.db
*.db-journal
prisma/migrations/

# Skills (development only)
/skills/
.claude
.z-ai-config

# Upload & temp files
upload/
download/

